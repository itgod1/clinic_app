.select-clinic-page.data-v-e8bdac7f {
  min-height: 100vh;
  background: #f5f7fa;
  display: flex;
  flex-direction: column;
  position: relative;
}
.nav-back.data-v-e8bdac7f {
  position: absolute;
  top: 100rpx;
  left: 30rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  z-index: 100;
}
.nav-back.data-v-e8bdac7f:active {
  background: rgba(255, 255, 255, 0.4);
}
.nav-back .nav-back-icon.data-v-e8bdac7f {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}
.page-header.data-v-e8bdac7f {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 30rpx 40rpx;
}
.page-header .title-section.data-v-e8bdac7f {
  text-align: center;
}
.page-header .title-section .main-title.data-v-e8bdac7f {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}
.page-header .title-section .sub-title.data-v-e8bdac7f {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}
.search-section.data-v-e8bdac7f {
  background: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.search-section .search-box.data-v-e8bdac7f {
  display: flex;
