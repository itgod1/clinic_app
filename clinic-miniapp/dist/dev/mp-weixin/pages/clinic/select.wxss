  font-size: 26rpx;
  color: #999;
}
.clinic-card.data-v-e8bdac7f {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 3rpx solid transparent;
  transition: all 0.3s;
}
.clinic-card.selected.data-v-e8bdac7f {
  border-color: #52c41a;
  box-shadow: 0 4rpx 24rpx rgba(82, 196, 26, 0.2);
}
.clinic-card.disabled.data-v-e8bdac7f {
  opacity: 0.7;
}
.clinic-card.data-v-e8bdac7f:active {
  transform: scale(0.98);
}
.clinic-card .card-main.data-v-e8bdac7f {
  display: flex;
  padding: 30rpx;
}
.clinic-card .card-main .clinic-logo.data-v-e8bdac7f {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-right: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.clinic-card .card-main .clinic-logo .logo-text.data-v-e8bdac7f {
